---
import BaseLayout from '../layouts/BaseLayout.astro';

const lang = 'en' as const;
const title = 'Videos — nayomy';
const description = 'Screen-recorded tutorials about AI tools — coming soon.';
---

<BaseLayout title={title} description={description} lang={lang}>
  <article class="placeholder">
    <span class="badge">Coming soon</span>
    <h1>Videos</h1>
    <p class="lead">
      Screen-recorded walkthroughs and tutorials, in Turkish.
      Production starts soon — stay tuned.
    </p>
  </article>
</BaseLayout>

<style>
  .placeholder {
    max-width: 720px;
    margin: 0 auto;
    padding: 96px 24px;
    text-align: center;
    color: var(--ink-2);
  }
  .badge {
    display: inline-block;
    padding: 6px 14px;
    border: 1px solid var(--line);
    border-radius: 999px;
    font-size: 13px;
    color: var(--ink-3);
    margin-bottom: 24px;
  }
  .placeholder h1 {
    font-size: clamp(36px, 5vw, 52px);
    font-weight: 700;
    letter-spacing: -0.025em;
    color: var(--ink);
    margin: 0 0 20px;
    line-height: 1.1;
  }
  .placeholder .lead {
    font-size: 18px;
    line-height: 1.7;
    margin: 0;
  }
</style>