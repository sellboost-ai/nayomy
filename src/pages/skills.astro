---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { useTranslations } from '../i18n/utils';

const lang = 'en' as const;
const t = useTranslations(lang);

const skills = await getCollection('skills');
const total = skills.length;
const repos = new Set(skills.map(s => s.data.repo)).size;
const cats = new Set(skills.map(s => s.data.category)).size;

const sortedSkills = [...skills].sort((a, b) => b.data.stars - a.data.stars);

const catCounts: Record<string, number> = {};
for (const s of skills) {
  catCounts[s.data.category] = (catCounts[s.data.category] ?? 0) + 1;
}
const sortedCats = Object.entries(catCounts).sort((a, b) => b[1] - a[1]);

let updatedAt: string | undefined;
try {
  const skillsJson = (await import('../../skills.json', { with: { type: 'json' } })) as any;
  updatedAt = skillsJson.default?.generated_at ?? skillsJson.generated_at;
} catch (_) {}
---

<BaseLayout
  title="Claude Skills · Nayomy"
  description="Every Claude Skill in one place — searchable, auto-updating catalog of agent skills published on GitHub."
  lang={lang}
  updatedAt={updatedAt}
>
  <section class="hero">
    <div class="container">
      <div class="hero-badge">
        <span class="dot"></span>
        <span>{t('hero.badge')} · {total} {t('home.skills_indexed')}</span>
      </div>
      <h1>
        {t('nav.skills')}<br />
        <span class="accent" style="font-size: clamp(20px, 3vw, 28px); font-weight: 400; letter-spacing: -0.01em;">{t('hero.tagline')}</span>
      </h1>
      <div class="hero-stats">
        <div class="hero-stat">
          <div class="num">{total}</div>
          <div class="label">{t('stats.skills')}</div>
        </div>
        <div class="hero-stat">
          <div class="num">{repos}</div>
          <div class="label">{t('stats.repos')}</div>
        </div>
        <div class="hero-stat">
          <div class="num">{cats}</div>
          <div class="label">{t('stats.cats')}</div>
        </div>
        <div class="hero-stat">
          <div class="num">{t('stats.daily')}</div>
          <div class="label">{t('stats.updates')}</div>
        </div>
      </div>
    </div>
  </section>

  <div class="container">
    <div class="cat-bar" id="catBar">
      <button class="cat-pill active" data-cat="__all__">
        All <span class="cat-count">{total}</span>
      </button>
      {sortedCats.map(([cat, count]) => (
        <button class="cat-pill" data-cat={cat}>
          {cat} <span class="cat-count">{count}</span>
        </button>
      ))}
    </div>

    <div class="section-header">
      <h2 class="section-title" id="resultsTitle">{t('home.topskills')}</h2>
      <span class="section-count" id="resultsCount">{total} {t('stats.skills').toLowerCase()}</span>
    </div>

    <div class="grid" id="cardGrid">
      {sortedSkills.map(skill => (
        <a class="card" data-cat={skill.data.category} href={`/skill/${skill.id}`}>
          <div class="card-head">
            <h3 class="card-name">{skill.data.name}</h3>
            <span class="card-cat">{skill.data.category}</span>
          </div>
          <p class="card-desc">{skill.data.description_en}</p>
          <div class="card-foot">
            <span class="card-repo">{skill.data.repo}</span>
            <div class="card-meta">
              <span class="card-stars">★ {skill.data.stars.toLocaleString()}</span>
              <span class="card-arrow">→</span>
            </div>
          </div>
        </a>
      ))}
    </div>

    <div class="load-more-wrap">
      <button class="load-more-btn" id="loadMoreBtn">Load more</button>
    </div>
  </div>
</BaseLayout>

<style>
  .hero-stat .num { font-size: clamp(24px, 4vw, 36px); font-weight: 700; letter-spacing: -0.03em; color: var(--brand); }
  .hero-stat .label { font-size: 12px; color: var(--ink-4); text-transform: uppercase; letter-spacing: 0.05em; margin-top: 2px; }

  .cat-bar { display: flex; flex-wrap: wrap; gap: 6px; padding: 24px 0 8px; }
  .cat-pill {
    display: inline-flex; align-items: center; gap: 5px;
    font-size: 11.5px; font-weight: 500; padding: 4px 10px;
    background: var(--bg-elevated); border: 1px solid var(--line);
    border-radius: 20px; color: var(--ink-3);
    cursor: pointer; transition: all 0.12s;
    font-family: inherit;
  }
  .cat-pill:hover { border-color: var(--line-strong); color: var(--ink-2); }
  .cat-pill.active {
    background: var(--ink); color: var(--bg); border-color: var(--ink);
  }
  .cat-pill.active .cat-count {
    color: rgba(255,255,255,0.5); background: rgba(255,255,255,0.1);
  }
  .cat-count {
    font-size: 10px; color: var(--ink-4); background: var(--bg-subtle);
    padding: 1px 5px; border-radius: 8px; font-weight: 600;
  }

  .section-header {
    display: flex; align-items: baseline; justify-content: space-between;
    padding: 24px 0 16px; border-bottom: 1px solid var(--line); margin-bottom: 20px;
  }
  .section-title { font-size: 15px; font-weight: 600; letter-spacing: -0.01em; }
  .section-count { font-size: 13px; color: var(--ink-3); }

  .card[data-hidden="true"] { display: none; }

  .load-more-wrap {
    display: flex; justify-content: center;
    padding: 32px 0 80px;
  }
  .load-more-btn {
    padding: 10px 24px;
    border: 1px solid var(--line);
    background: var(--bg-elevated);
    color: var(--ink-2);
    border-radius: 8px;
    font-family: inherit;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.12s;
  }
  .load-more-btn:hover {
    border-color: var(--brand);
    color: var(--brand);
  }
  .load-more-btn[data-hidden="true"] { display: none; }
</style>

<script>
  const INITIAL = 24;
  const BATCH = 48;

  let activeCat = '__all__';
  let visibleCount = INITIAL;

  const grid = document.getElementById('cardGrid');
  const pills = document.querySelectorAll('.cat-pill');
  const loadMoreBtn = document.getElementById('loadMoreBtn');
  const resultsCount = document.getElementById('resultsCount');
  const allCards = Array.from(grid?.querySelectorAll('.card') ?? []) as HTMLElement[];

  function applyFilter() {
    const filtered = activeCat === '__all__'
      ? allCards
      : allCards.filter(c => c.dataset.cat === activeCat);

    allCards.forEach(c => c.setAttribute('data-hidden', 'true'));
    filtered.slice(0, visibleCount).forEach(c => c.removeAttribute('data-hidden'));

    const totalInFilter = filtered.length;
    const showing = Math.min(visibleCount, totalInFilter);

    if (resultsCount) {
      resultsCount.textContent = `${showing} of ${totalInFilter}`;
    }

    if (loadMoreBtn) {
      if (showing >= totalInFilter) {
        loadMoreBtn.setAttribute('data-hidden', 'true');
      } else {
        loadMoreBtn.removeAttribute('data-hidden');
      }
    }
  }

  pills.forEach(pill => {
    pill.addEventListener('click', () => {
      pills.forEach(p => p.classList.remove('active'));
      pill.classList.add('active');
      activeCat = (pill as HTMLElement).dataset.cat ?? '__all__';
      visibleCount = INITIAL;
      applyFilter();
      window.scrollTo({ top: (grid?.offsetTop ?? 0) - 100, behavior: 'smooth' });
    });
  });

  loadMoreBtn?.addEventListener('click', () => {
    visibleCount += BATCH;
    applyFilter();
  });

  applyFilter();
</script>