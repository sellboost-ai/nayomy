---
import BaseLayout from '../../layouts/BaseLayout.astro';

const lang = 'tr' as const;
const title = '404 — Sayfa bulunamadı · nayomy';
const description = 'Aradığınız sayfa silinmiş veya taşınmış olabilir.';
---

<BaseLayout title={title} description={description} lang={lang}>
  <div class="nf">
    <div class="nf-mark">404</div>
    <h1>Sayfa bulunamadı</h1>
    <p>Aradığınız sayfa silinmiş veya taşınmış olabilir.</p>
    <div class="nf-links">
      <a href="/tr" class="nf-btn">Ana sayfa</a>
      <a href="/tr" class="nf-link">Skill'ler →</a>
      <a href="/tr/mcp" class="nf-link">MCP Sunucuları →</a>
      <a href="/tr/about" class="nf-link">Hakkında →</a>
    </div>
  </div>
</BaseLayout>

<style>
  .nf {
    max-width: 560px;
    margin: 0 auto;
    padding: 96px 24px 120px;
    text-align: center;
  }
  .nf-mark {
    font-family: 'Geist Mono', ui-monospace, monospace;
    font-size: clamp(80px, 14vw, 144px);
    font-weight: 800;
    letter-spacing: -0.04em;
    color: var(--ink-4);
    line-height: 1;
    margin-bottom: 16px;
  }
  .nf h1 {
    font-size: clamp(24px, 4vw, 32px);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin-bottom: 12px;
  }
  .nf p {
    color: var(--ink-3);
    font-size: 16px;
    line-height: 1.6;
    margin-bottom: 32px;
  }
  .nf-links {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 18px;
    flex-wrap: wrap;
  }
  .nf-btn {
    display: inline-flex;
    align-items: center;
    background: var(--ink);
    color: var(--bg);
    padding: 9px 18px;
    border-radius: 7px;
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
    transition: opacity 0.12s;
  }
  .nf-btn:hover { opacity: 0.85; }
  .nf-link {
    color: var(--ink-3);
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
    transition: color 0.12s;
  }
  .nf-link:hover { color: var(--ink); }
</style>
