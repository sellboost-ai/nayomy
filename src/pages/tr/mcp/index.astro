---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { useTranslations } from '../../../i18n/utils';

const lang = 'tr' as const;
const t = useTranslations(lang);

const servers = await getCollection('mcp');
const total = servers.length;
const cats  = new Set(servers.map(s => s.data.category)).size;

const top12 = [...servers]
  .sort((a, b) => b.data.stars - a.data.stars)
  .slice(0, 12);

const catCounts: Record<string, number> = {};
for (const s of servers) {
  catCounts[s.data.category] = (catCounts[s.data.category] ?? 0) + 1;
}
const sortedCats = Object.entries(catCounts).sort((a, b) => b[1] - a[1]);

let updatedAt: string | undefined;
try {
  const mcpJson = (await import('../../../../mcp.json', { with: { type: 'json' } })) as any;
  updatedAt = mcpJson.default?.generated_at ?? mcpJson.generated_at;
} catch (_) {}
---

<BaseLayout
  title="MCP Sunucuları · Nayomy"
  description="Model Context Protocol sunucuları — Claude ve diğer AI'ları dış sistemlere bağlar. Aranabilir, otomatik güncellenen katalog."
  lang={lang}
  updatedAt={updatedAt}
>
  <section class="hero">
    <div class="container">
      <div class="hero-badge">
        <span class="dot"></span>
        <span>{t('hero.badge')} · {total} {t('home.servers_indexed')}</span>
      </div>
      <h1>
        {t('mcp.title')}<br />
        <span class="accent" style="font-size: clamp(20px, 3vw, 28px); font-weight: 400; letter-spacing: -0.01em;">{t('mcp.tagline')}</span>
      </h1>
      <div class="hero-stats">
        <div class="hero-stat">
          <div class="num">{total}</div>
          <div class="label">{t('mcp.servers_label')}</div>
        </div>
        <div class="hero-stat">
          <div class="num">{cats}</div>
          <div class="label">{t('stats.cats')}</div>
        </div>
        <div class="hero-stat">
          <div class="num">{t('stats.daily')}</div>
          <div class="label">{t('stats.updates')}</div>
        </div>
      </div>
    </div>
  </section>

  <div class="container">
    <div class="cat-bar">
      {sortedCats.map(([cat, count]) => (
        <span class="cat-pill">
          {cat} <span class="cat-count">{count}</span>
        </span>
      ))}
    </div>

    <div class="section-header">
      <h2 class="section-title">{t('home.top_mcp')}</h2>
      <span class="section-count">{t('home.viewall')} {total}</span>
    </div>
    <div class="grid">
      {top12.map(s => (
        <a class="card" href={`/tr/mcp/${s.id}`}>
          <div class="card-head">
            <h3 class="card-name">{s.data.name}</h3>
            <span class="card-cat">{s.data.category}</span>
          </div>
          <p class="card-desc">{s.data.description_tr ?? s.data.description}</p>
          <div class="card-foot">
            <span class="card-repo">{s.data.repo}</span>
            <div class="card-meta">
              {s.data.language && <span class="card-lang">{s.data.language}</span>}
              <span class="card-stars">★ {s.data.stars.toLocaleString()}</span>
              <span class="card-arrow">→</span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .hero-stat .num { font-size: clamp(24px, 4vw, 36px); font-weight: 700; letter-spacing: -0.03em; color: var(--ink); }
  .hero-stat .label { font-size: 12px; color: var(--ink-4); text-transform: uppercase; letter-spacing: 0.05em; margin-top: 2px; }
  .cat-bar { display: flex; flex-wrap: wrap; gap: 6px; padding: 24px 0 8px; }
  .cat-pill {
    display: inline-flex; align-items: center; gap: 5px;
    font-size: 11.5px; font-weight: 500; padding: 4px 10px;
    background: var(--bg-elevated); border: 1px solid var(--line);
    border-radius: 20px; color: var(--ink-3); cursor: default; transition: border-color 0.12s;
  }
  .cat-pill:hover { border-color: var(--line-strong); color: var(--ink-2); }
  .cat-count {
    font-size: 10px; color: var(--ink-4); background: var(--bg-subtle);
    padding: 1px 5px; border-radius: 8px; font-weight: 600;
  }
  .section-header {
    display: flex; align-items: baseline; justify-content: space-between;
    padding: 24px 0 16px; border-bottom: 1px solid var(--line); margin-bottom: 20px;
  }
  .section-title { font-size: 15px; font-weight: 600; letter-spacing: -0.01em; }
  .section-count { font-size: 13px; color: var(--ink-3); }
  .card-lang {
    font-size: 10px; color: var(--ink-4); background: var(--bg-subtle);
    border: 1px solid var(--line); border-radius: 3px; padding: 1px 5px; font-weight: 500;
  }
</style>
