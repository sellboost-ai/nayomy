---
import BaseLayout from '../layouts/BaseLayout.astro';

const lang = 'en' as const;
const title = 'About — nayomy';
const description = 'Discover what each AI tool can do — from Claude and ChatGPT to the ecosystems that grow around them.';
---

<BaseLayout title={title} description={description} lang={lang}>
  <article class="about">
    <h1>About nayomy</h1>

    <p class="lead">
      nayomy is the knowledge library for AI — a single place to discover what each tool can do,
      what makes it different, and how to get more out of it.
    </p>

    <p>
      We cover the major AI products in depth: Claude, ChatGPT, Gemini, Cursor, and the tools shaping
      how people build, write, and create with AI. For each, we go beyond the marketing page — into the
      capabilities, the limits, and the ecosystems that grow around them.
    </p>

    <h2>What you'll find here</h2>
    <ul>
      <li><strong>A reference for AI products</strong> — model lineups, pricing, real-world use cases, and honest comparisons.</li>
      <li><strong>A library of extensions</strong> — agent skills, MCP servers, editor rules, custom assistants, and other resources that make these tools more powerful.</li>
      <li><strong>Coverage that grows with the ecosystem</strong> — new tools, new languages, new ways to discover AI.</li>
    </ul>
  </article>
</BaseLayout>

<style>
  .about {
    max-width: 720px;
    margin: 0 auto;
    padding: 56px 24px 96px;
    color: var(--ink-2);
    line-height: 1.7;
    font-size: 16px;
  }
  .about h1 {
    font-size: clamp(32px, 5vw, 44px);
    font-weight: 700;
    letter-spacing: -0.025em;
    color: var(--ink);
    margin-bottom: 24px;
    line-height: 1.1;
  }
  .about h2 {
    font-size: 20px;
    font-weight: 700;
    letter-spacing: -0.015em;
    color: var(--ink);
    margin: 40px 0 12px;
  }
  .about p { margin: 0 0 16px; }
  .about .lead { font-size: 18px; color: var(--ink-2); margin-bottom: 32px; }
  .about ul { padding-left: 22px; margin: 0 0 20px; }
  .about li { margin-bottom: 10px; }
  .about a {
    color: var(--ink);
    text-decoration: underline;
    text-decoration-color: var(--line-strong);
    text-underline-offset: 2px;
  }
  .about a:hover { text-decoration-color: var(--ink); }
  .about strong { color: var(--ink); font-weight: 600; }
  .about em { color: var(--ink); font-style: italic; }
  .about .signoff {
    margin-top: 48px;
    padding-top: 24px;
    border-top: 1px solid var(--line);
    font-size: 14px;
    color: var(--ink-3);
  }
</style>
