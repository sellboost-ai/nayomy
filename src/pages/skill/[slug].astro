---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import InstallBlock from '../../components/InstallBlock.astro';
import { useTranslations } from '../../i18n/utils';

const lang = 'en' as const;
const t = useTranslations(lang);

export async function getStaticPaths() {
  const skills = await getCollection('skills');
  return skills.map(skill => ({
    params: { slug: skill.id },
    props: { skill },
  }));
}

type Props = { skill: CollectionEntry<'skills'> };
const { skill } = Astro.props;
const { name, description_en, category, repo, stars, url, path } = skill.data;
---

<BaseLayout title={`${name} · Nayomy`} description={description_en} lang={lang}>
  <div class="container">
    <div class="detail-page">

      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">{t('nav.skills')}</a>
        <span class="sep">/</span>
        <span>{category}</span>
        <span class="sep">/</span>
        <span class="crumb-current">{name}</span>
      </nav>

      <div class="detail-header">
        <div class="detail-meta">
          <span class="cat-badge">{category}</span>
          <span class="stars-count">★ {stars.toLocaleString()}</span>
        </div>
        <h1 class="detail-title">{name}</h1>
        <p class="detail-desc">{description_en}</p>
      </div>

      <InstallBlock lang={lang} name={name} repo={repo} path={path} />

      <dl class="detail-info">
        <div class="info-row">
          <dt>{t('skill.category')}</dt>
          <dd>{category}</dd>
        </div>
        <div class="info-row">
          <dt>{t('skill.source')}</dt>
          <dd>
            <a href={url} target="_blank" rel="noopener noreferrer">{repo}</a>
          </dd>
        </div>
        <div class="info-row">
          <dt>{t('skill.stars')}</dt>
          <dd>★ {stars.toLocaleString()}</dd>
        </div>
      </dl>

    </div>
  </div>
</BaseLayout>

<style>
  .detail-page {
    max-width: 760px;
    padding: 32px 0 80px;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    color: var(--ink-3);
    margin-bottom: 28px;
  }
  .breadcrumb a { color: var(--ink-3); text-decoration: none; }
  .breadcrumb a:hover { color: var(--ink); }
  .breadcrumb .sep { color: var(--ink-4); }
  .breadcrumb .crumb-current { color: var(--ink-2); }

  .detail-header { margin-bottom: 28px; }
  .detail-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 12px;
  }
  .cat-badge {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 600;
    padding: 3px 8px;
    background: var(--bg-subtle);
    border: 1px solid var(--line);
    border-radius: 4px;
    color: var(--ink-3);
  }
  .stars-count { font-size: 13px; color: var(--ink-3); font-weight: 500; }
  .detail-title {
    font-size: clamp(26px, 4vw, 38px);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.1;
    margin-bottom: 12px;
  }
  .detail-desc {
    font-size: 15.5px;
    color: var(--ink-3);
    line-height: 1.65;
    max-width: 640px;
  }

  .detail-info {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .info-row {
    display: flex;
    align-items: baseline;
    padding: 11px 16px;
    border-bottom: 1px solid var(--line);
    font-size: 13.5px;
    gap: 16px;
  }
  .info-row:last-child { border-bottom: none; }
  .info-row dt { color: var(--ink-3); font-weight: 500; min-width: 90px; flex-shrink: 0; }
  .info-row dd { color: var(--ink-2); }
  .info-row dd a {
    color: var(--ink-2);
    text-decoration: none;
    font-family: 'Geist Mono', monospace;
    font-size: 12.5px;
  }
  .info-row dd a:hover { color: var(--ink); text-decoration: underline; }
</style>
