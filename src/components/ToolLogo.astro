---
interface Props {
  name: string;
  color?: string;
  size?: number;
}

const { name, color = '#0a0a0a', size = 64 } = Astro.props;
const letter = (name?.[0] ?? '?').toUpperCase();
const fontSize = Math.round(size * 0.55);
const radius = Math.round(size * 0.22);
---

<span
  class="tool-logo"
  style={`width:${size}px;height:${size}px;background:${color};border-radius:${radius}px;font-size:${fontSize}px;`}
  aria-hidden="true"
>{letter}</span>

<style>
  .tool-logo {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-family: 'Geist', system-ui, sans-serif;
    font-weight: 800;
    letter-spacing: -0.03em;
    flex-shrink: 0;
  }
</style>
